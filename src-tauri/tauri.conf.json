{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Musarrif",
  "version": "0.1.0",
  "identifier": "com.musarrif.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 5173",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "copyright": "© 2026 Luis Rodrigues",
    "category": "Education",
    "shortDescription": "Arabic verb conjugator",
    "longDescription": "Muṣarrif is an Arabic verb conjugation reference and drill companion.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Muṣarrif",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  }
}
